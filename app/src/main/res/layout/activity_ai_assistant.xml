<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".AIAssistantActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarAi"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background_dark"
        app:title="AI Assistant"
        app:titleTextColor="@color/cyan_accent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardAiResponse"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        app:cardBackgroundColor="@color/surface_dark"
        app:cardCornerRadius="24dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/purple_primary"
        app:layout_constraintTop_toBottomOf="@id/toolbarAi"
        app:layout_constraintBottom_toTopOf="@id/fabMic"
        android:layout_marginBottom="48dp">
        
        <TextView
            android:id="@+id/tvAiResponse"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="How can I help you navigate the campus today?"
            android:textColor="@color/text_light"
            android:textSize="22sp"
            android:gravity="center"
            android:padding="32dp" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:fabSize="auto"
        app:fabCustomSize="80dp"
        app:maxImageSize="40dp"
        android:src="@android:drawable/ic_btn_speak_now"
        app:tint="@color/background_dark"
        app:backgroundTint="@color/cyan_accent"
        app:layout_constraintBottom_toTopOf="@+id/tvListeningStatus"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvListeningStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap to Speak"
        android:textColor="@color/cyan_accent"
        android:textStyle="bold"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
