<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".IndoorMapActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarIndoor"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background_dark"
        app:title="Indoor Map"
        app:titleTextColor="@color/cyan_accent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabFloorSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        app:tabTextColor="@color/text_light"
        app:tabSelectedTextColor="@color/cyan_accent"
        app:tabIndicatorColor="@color/cyan_accent"
        app:layout_constraintTop_toBottomOf="@id/toolbarIndoor">
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ground Floor" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="First Floor" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Second Floor" />
    </com.google.android.material.tabs.TabLayout>

    <!-- Placeholder for an image-based indoor map. -->
    <ImageView
        android:id="@+id/ivIndoorMap"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="centerInside"
        android:src="@android:drawable/ic_menu_mapmode"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/tabFloorSelector"
        app:layout_constraintBottom_toTopOf="@+id/tvRoomInfo" />

    <TextView
        android:id="@+id/tvRoomInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select a floor to view classrooms, labs, and exits."
        android:textColor="@color/white"
        android:padding="16dp"
        android:gravity="center"
        android:background="@color/surface_dark"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
